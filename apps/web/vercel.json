{
  "rewrites": [
    {
      "source": "/auth/:path*",
      "destination": "https://repoapi-production-b2c5.up.railway.app/auth/:path*"
    },
    {
      "source": "/trpc",
      "destination": "https://repoapi-production-b2c5.up.railway.app/trpc"
    },
    {
      "source": "/trpc/:path*",
      "destination": "https://repoapi-production-b2c5.up.railway.app/trpc/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://repoapi-production-b2c5.up.railway.app/api/:path*"
    },
    {
      "source": "/forms/unlock",
      "destination": "https://repoapi-production-b2c5.up.railway.app/forms/unlock"
    }
  ],
  "headers": [
    {
      "source": "/auth/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    }
  ]
}
